{
  "manifest_version": 3,
  "name": "OpenFOCUS",
  "version": "2.0.0",
  "description": "An open-source productivity workspace for your browser.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "optional_permissions": [
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "icons": {
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "openfocus@example.com",
      "strict_min_version": "121.0"
    }
  }
}